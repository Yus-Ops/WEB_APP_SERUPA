# Frontend Vue (frontend/) — variabel Vite, AMAN di klien (prefix VITE_).
# Salin file ini menjadi `.env.local` dan isi nilainya untuk mode LIVE.
#
# Jika SEMUA dikosongkan, frontend otomatis berjalan dalam MODE DEMO:
# memakai korpus contoh bawaan + kemiripan trigram di sisi klien, sehingga
# `npm run dev` langsung menampilkan UI lengkap tanpa backend.

# URL layanan Python (FastAPI) — sumber operasi AI (/check, /add).
# Kosongkan untuk mode demo.
VITE_PYTHON_API=

# Supabase (untuk membaca data peta `theses_map` & login admin).
# Kosongkan untuk mode demo (peta memakai data contoh).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
