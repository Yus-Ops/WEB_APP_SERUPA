# ============================================================================
# Serupa — contoh variabel lingkungan. Salin ke `.env` (jangan commit .env).
#   cp .env.example .env
# Lihat INTEGRATION.md untuk cara mendapatkan tiap nilai.
# ============================================================================

# --- Mode data frontend -----------------------------------------------------
# 'mock' = semuanya lokal (default, tanpa backend). 'live' = Supabase + HF.
VITE_DATA_MODE=mock

# --- Supabase (PUBLIK — aman di browser; dijaga oleh RLS) -------------------
# Project Settings → API. URL & anon/public key.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Domain email internal untuk login NIM (PRD §8). Login mahasiswa memakai
# {nim}@{domain}; email asli tetap dicatat untuk pemulihan.
VITE_STUDENT_EMAIL_DOMAIN=std.unissula.ac.id

# Endpoint fungsi scan. Default '/api/scan' (satu domain Vercel).
VITE_SCAN_API_URL=/api/scan

# ============================================================================
# RAHASIA SERVER — HANYA di Vercel Environment Variables / .env lokal.
# JANGAN diberi prefix VITE_ (agar tidak ikut ter-bundle ke browser).
# ============================================================================

# --- Supabase (server) ------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Project Settings → API → service_role secret. Mem-bypass RLS. RAHASIA.
SUPABASE_SERVICE_ROLE_KEY=

# --- Hugging Face -----------------------------------------------------------
# Access Token (huggingface.co/settings/tokens), scope: read (atau Inference).
HF_TOKEN=
# Model embedding. Default multilingual, 1024-dim, kuat utk Bahasa Indonesia.
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
# Pooling token→kalimat: 'cls' (BGE) atau 'mean' (sebagian sentence-transformers).
EMBED_POOLING=cls
EMBED_NORMALIZE=true
# Opsional: endpoint embedding PRIVAT (direkomendasikan utk data sensitif, §12).
# Bila diisi, dipakai menggantikan Inference API serverless. Contoh untuk HF
# Space embedding milik proyek ini (lihat INTEGRATION.md §F):
#   EMBED_ENDPOINT_URL=https://<user>-serupa-embed.hf.space/embed
EMBED_ENDPOINT_URL=
# Opsional: instruksi/prefix query & passage (mis. untuk keluarga e5).
EMBED_QUERY_INSTRUCTION=
EMBED_PASSAGE_INSTRUCTION=

# Batas maksimum Top-N yang boleh diminta frontend.
SCAN_TOP_N_MAX=20
