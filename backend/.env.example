# backend/.env — variabel layanan Python (server-side SAJA).
# Salin jadi `.env` lalu isi:  cp .env.example .env
# Di HF Space, nilai-nilai ini diisi lewat Settings -> Variables and secrets
# (BUKAN dari file ini — .env tidak ikut ke HF).

# ── Supabase ───────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
# service_role key — HANYA di backend / HF secrets. JANGAN PERNAH di frontend.
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Keamanan ───────────────────────────────────────────────────────
# Rahasia panjang acak untuk melindungi endpoint /add (gerbang korpus, Aturan B).
ADMIN_KEY=ganti-dengan-rahasia-panjang-acak

# Domain frontend untuk CORS; biarkan * hanya saat dev lokal.
FRONTEND_ORIGIN=https://your-app.vercel.app

# ── Indexer (LOKAL saja) ───────────────────────────────────────────
# Path CSV korpus untuk indexer.py (dijalankan dari folder backend/).
CORPUS_CSV=Corpus.csv
# (Opsional) jumlah klaster KMeans.
# N_CLUSTERS=10
